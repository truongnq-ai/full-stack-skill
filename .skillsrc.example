# Example configuration for full-stack-skill
# Generated by: full-stack-skill init
#
# 'skills' list = Active skill categories. Remove a category to disable it.
# 'exclude': Sub-skill IDs to skip during sync.
# 'custom_overrides': Skill IDs to PROTECT from being overwritten by sync.
#
# Run 'fss list-skills' to view all available skills.

registry: https://github.com/truongnq-ai/full-stack-skill

agents:
  - cursor
  - claude
  - copilot

skills:
  common:
    ref: common-v1.5.4
  typescript:
    ref: typescript-v1.0.6
  react:
    ref: react-v1.0.3
  nestjs:
    ref: nestjs-v1.1.3
  nextjs:
    ref: nextjs-v1.1.3

# workflows: true
# custom_overrides: []
