{
  "name": "@truongnq-ai/full-stack-skill",
  "version": "2026.03.28",
  "description": "A CLI to manage and sync full-stack AI agent skills for Cursor, Claude, Copilot, Windsurf, Antigravity, OpenClaw, and more.",
  "main": "dist/index.js",
  "bin": {
    "full-stack-skill": "dist/index.js",
    "fss": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "validate": "tsx src/index.ts validate",
    "validate:all": "tsx src/index.ts validate --all",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "lint:check": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "ai",
    "agent",
    "cursor",
    "claude",
    "copilot",
    "cli",
    "antigravity",
    "openclaw",
    "full-stack"
  ],
  "author": "Truong Nguyen",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "dotenv": "^17.2.3",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.5",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.0.0",
    "tsx": "^4.21.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.17",
    "vite": "^7.0.0",
    "vitest": "^4.0.17"
  }
}
